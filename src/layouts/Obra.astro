---
import Base from './Base.astro';
import galleryData from '../data/gallery.json';
import worksData from '../data/works.json';
import relationsData from '../data/map-relations.json';
import referencesData from '../data/references.json';
import publicationsData from '../data/publications.json';

type GalleryItem = { src: string; caption: string | null };

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    year: string;
    location: string;
    description?: string;
    hero?: string;
    credits?: Array<{role: string; name: string}>;
    press?: Array<{source: string; url: string; title: string}>;
    publications?: Array<{title: string; author?: string; pages?: string; url?: string; note?: string}>;
    series?: string;
    lang?: 'pt' | 'en';
  };
}

const { frontmatter } = Astro.props;
const lang = frontmatter.lang || 'pt';
const isEN = lang === 'en';
const prefix = isEN ? '/en' : '';
const seoTitle = `Felipe Sztutman — ${frontmatter.title}`;
const seoDesc = frontmatter.description || `${frontmatter.title} (${frontmatter.year}) — ${frontmatter.location}. Felipe Sztutman.`;
const slug = Astro.url.pathname.replace(/^\/(?:en\/)?obras\//, '').replace(/\/$/, '');
const items: GalleryItem[] = (galleryData as Record<string, GalleryItem[]>)[slug] || [];
const ogImage = items[0]?.src || frontmatter.hero || undefined;

const works = ((worksData as any).works || []).slice().sort((a: any, b: any) => a.numero.localeCompare(b.numero));
const references = (referencesData as any).references || [];
const publications = (publicationsData as any).publications || [];
const relationSeeds = (relationsData as any).relations || [];

const work = works.find((entry: any) => entry.slug === slug) || null;
const pulse = work?.corPulso || '#00ccff';
const currentIndex = works.findIndex((entry: any) => entry.slug === slug);
const previousWork = currentIndex > 0 ? works[currentIndex - 1] : null;
const nextWork = currentIndex >= 0 && currentIndex < works.length - 1 ? works[currentIndex + 1] : null;

const writingModules = import.meta.glob('../pages/escritos/*.md', { eager: true }) as Record<string, any>;
const writings = Object.entries(writingModules)
  .filter(([path]) => !path.endsWith('index.astro'))
  .map(([path, mod]) => {
    const id = path.split('/').pop()!.replace('.md', '');
    return {
      slug: id,
      title: mod.frontmatter.title as string,
      href: `${prefix}/escritos/${id}`,
    };
  });

function resolveEntity(kind: string, id: string) {
  if (kind === 'OBRA') {
    const found = works.find((entry: any) => entry.slug === id);
    return found ? { label: found.titulo, href: `${prefix}/obras/${found.slug}` } : null;
  }
  if (kind === 'ESCRITO') {
    const found = writings.find((entry) => entry.slug === id);
    return found ? { label: found.title, href: found.href } : null;
  }
  if (kind === 'PUBLICACAO') {
    const found = publications.find((entry: any) => entry.slug === id);
    return found ? { label: found.titulo, href: found.currentPublicPath || `${prefix}/publicacoes` } : null;
  }
  if (kind === 'REFERENCIA') {
    const found = references.find((entry: any) => entry.slug === id);
    return found ? { label: found.label, href: null } : null;
  }
  return null;
}

const publicRelations = relationSeeds
  .filter((relation: any) => relation.visibility === 'PUBLICA' && (relation.source === slug || relation.target === slug))
  .map((relation: any) => {
    const isSource = relation.source === slug;
    const relatedKind = isSource ? relation.targetKind : relation.sourceKind;
    const relatedId = isSource ? relation.target : relation.source;
    const related = resolveEntity(relatedKind, relatedId);
    return related ? {
      label: related.label,
      href: related.href,
      relationLabel: relation.label,
      notes: relation.notes,
      relationType: relation.relationType,
    } : null;
  })
  .filter(Boolean);

const dossierRows = [
  work?.numero ? { label: isEN ? 'Number' : 'Número', value: work.numero } : null,
  work?.status ? { label: isEN ? 'Status' : 'Status', value: work.status === 'A_CONFIRMAR' ? 'A CONFIRMAR' : 'REALIZADA' } : null,
  work?.ano ? { label: isEN ? 'Year' : 'Ano', value: String(work.ano) } : null,
  work?.local ? { label: isEN ? 'Location' : 'Local', value: work.local } : null,
  work?.contexto ? { label: isEN ? 'Context' : 'Contexto', value: work.contexto } : null,
  work?.tipo ? { label: isEN ? 'Type' : 'Tipo', value: work.tipo.replaceAll('_', ' ') } : null,
  work?.serie ? { label: isEN ? 'Series' : 'Série', value: work.serie } : null,
  work?.tecnicaMedium?.length ? { label: isEN ? 'Technique / medium' : 'Técnica / medium', value: work.tecnicaMedium.join(' · ') } : null,
  work?.fichaTecnica?.extensao ? { label: isEN ? 'Extension' : 'Extensão', value: work.fichaTecnica.extensao } : null,
  work?.fichaTecnica?.duracao ? { label: isEN ? 'Duration' : 'Duração', value: work.fichaTecnica.duracao } : null,
  work?.fichaTecnica?.realizacao?.length ? { label: isEN ? 'Realization' : 'Realização', value: work.fichaTecnica.realizacao.join(' · ') } : null,
].filter(Boolean);

function imageAlt(item: GalleryItem, index: number) {
  const cleanCaption = item.caption?.split('· foto')[0]?.trim();
  return cleanCaption ? `${frontmatter.title} — ${cleanCaption}` : `${frontmatter.title} — ${isEN ? 'image' : 'imagem'} ${index + 1}`;
}

function normalizePublicationUrl(url?: string) {
  if (!url) return null;
  if (url.includes('/publicacoes/')) return `${prefix}/publicacoes`;
  return url;
}
---
<Base
  title={seoTitle}
  description={seoDesc}
  lang={lang}
  schemaType="ArtWork"
  schemaName={frontmatter.title}
  schemaDate={frontmatter.year}
  schemaLocation={frontmatter.location}
  ogImage={ogImage}
  fullBleed={true}
  showHeader={false}
  showFooter={false}
  bodyClass="page-obra"
>
  <article class="obra-page" style={`--pulse:${pulse};`}>
    <section class="obra-entry">
      <a href={`${prefix}/#obras`} class="back">{isEN ? '← archive' : '← arquivo'}</a>
      <div class="eyebrow">
        {work?.numero ? `OBRA Nº ${work.numero}` : 'OBRA'} · {frontmatter.year}
        {work?.status === 'A_CONFIRMAR' && <span class="status-chip">A CONFIRMAR</span>}
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="entry-meta">{work?.contexto || frontmatter.location}</div>
    </section>

    <section class="panel dossier">
      <div class="panel-kicker">{isEN ? 'Dossier' : 'Dossiê'}</div>
      {frontmatter.description && <p class="lead">{frontmatter.description}</p>}
      <dl>
        {dossierRows.map((row: any) => (
          <div class="row">
            <dt>{row.label}</dt>
            <dd>{row.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="narrative">
      <div class="section-kicker">{isEN ? 'Text' : 'Texto'}</div>
      <div class="narrative-body">
        <slot />
      </div>
    </section>

    {publicRelations.length > 0 && (
      <section class="panel relations">
        <div class="panel-kicker">{isEN ? 'Public relations' : 'Relações públicas'}</div>
        <div class="relation-list">
          {publicRelations.map((relation: any) => (
            <div class="relation-item">
              <div class="relation-label">{relation.relationLabel || (isEN ? 'Relation' : 'Relação')}</div>
              {relation.href ? (
                <a href={relation.href} class="relation-target">{relation.label}</a>
              ) : (
                <span class="relation-target static">{relation.label}</span>
              )}
              {relation.notes && <div class="relation-notes">{relation.notes}</div>}
            </div>
          ))}
        </div>
      </section>
    )}

    {(frontmatter.credits?.length || frontmatter.publications?.length || frontmatter.press?.length) && (
      <section class="panel support">
        {frontmatter.credits && frontmatter.credits.length > 0 && (
          <div class="support-block">
            <div class="panel-kicker">{isEN ? 'Credits' : 'Créditos'}</div>
            <div class="support-list">
              {frontmatter.credits.map((credit) => (
                <div class="support-row">
                  <span>{credit.role}</span>
                  <strong>{credit.name}</strong>
                </div>
              ))}
            </div>
          </div>
        )}

        {frontmatter.publications && frontmatter.publications.length > 0 && (
          <div class="support-block">
            <div class="panel-kicker">{isEN ? 'Publication' : 'Publicação'}</div>
            <div class="support-list">
              {frontmatter.publications.map((publication) => (
                <div class="support-row support-row-stack">
                  {normalizePublicationUrl(publication.url) ? <a href={normalizePublicationUrl(publication.url)!}><strong>{publication.title}</strong></a> : <strong>{publication.title}</strong>}
                  {(publication.author || publication.pages) && <span>{publication.author}{publication.author && publication.pages ? ' · ' : ''}{publication.pages || ''}</span>}
                  {publication.note && <span>{publication.note}</span>}
                </div>
              ))}
            </div>
          </div>
        )}

        {frontmatter.press && frontmatter.press.length > 0 && (
          <div class="support-block">
            <div class="panel-kicker">{isEN ? 'Press' : 'Imprensa'}</div>
            <div class="support-list">
              {frontmatter.press.map((press) => (
                <div class="support-row support-row-stack">
                  <a href={press.url} target="_blank"><strong>{press.source}</strong></a>
                  <span>{press.title}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    {items.length > 0 && (
      <section class="gallery">
        <div class="section-kicker">{isEN ? 'Documentation' : 'Documentação'}</div>
        <div class="gallery-grid">
          {items.map((item, index) => (
            <figure class:list={[ 'gallery-item', index === 0 && 'hero' ]}>
              <img src={item.src} alt={imageAlt(item, index)} loading={index === 0 ? 'eager' : 'lazy'} />
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    {(previousWork || nextWork) && (
      <nav class="archive-nav" aria-label={isEN ? 'Archive navigation' : 'Navegação do arquivo'}>
        {previousWork ? (
          <a href={`${prefix}/obras/${previousWork.slug}`} class="archive-nav-item prev">
            <span class="archive-nav-label">{isEN ? 'Previous' : 'Anterior'}</span>
            <strong>{previousWork.numero} · {previousWork.titulo}</strong>
          </a>
        ) : <span />}
        {nextWork ? (
          <a href={`${prefix}/obras/${nextWork.slug}`} class="archive-nav-item next">
            <span class="archive-nav-label">{isEN ? 'Next' : 'Próxima'}</span>
            <strong>{nextWork.numero} · {nextWork.titulo}</strong>
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</Base>

<style is:global>
body.page-obra{background:#050505;color:#f1ece3}
body.page-obra a{text-decoration:none}
</style>

<style>
:root{--paper:#ece5d8;--ink:#131313;--line:rgba(255,255,255,.1);--paper-line:rgba(17,17,17,.16)}
.obra-page{background:#050505;color:#f1ece3;padding:1.25rem 1rem 3rem}
.obra-entry{padding:0 0 2rem;border-bottom:1px solid var(--line);margin-bottom:1.5rem}
.back,.eyebrow,.panel-kicker,.section-kicker,.status-chip{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase}
.back{display:inline-block;color:rgba(255,255,255,.55);margin-bottom:1.25rem}
.back:hover{color:#fff}
.eyebrow{color:rgba(255,255,255,.5);margin-bottom:1rem;display:flex;gap:.5rem;align-items:center;flex-wrap:wrap}
.status-chip{padding:.28rem .4rem;border:1px solid rgba(255,255,255,.18);color:rgba(255,255,255,.65)}
.obra-entry h1{font:900 clamp(2.8rem,10vw,8rem)/.9 var(--sans);letter-spacing:-.05em;max-width:10ch}
.entry-meta{margin-top:.85rem;font:.82rem/1.5 var(--mono);text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.48)}
.panel{background:var(--paper);color:var(--ink);padding:1rem;border-top:2px solid var(--pulse);margin:0 0 1.5rem}
.panel-kicker,.section-kicker{color:rgba(17,17,17,.48);margin-bottom:1rem}
.lead{font:400 1.05rem/1.6 var(--sans);margin-bottom:1rem;max-width:56ch}
.dossier dl{display:grid;gap:.55rem}
.row{display:grid;grid-template-columns:140px 1fr;gap:.75rem;padding-top:.55rem;border-top:1px solid var(--paper-line)}
.row dt{font:.72rem/1.4 var(--mono);letter-spacing:.08em;text-transform:uppercase;color:rgba(17,17,17,.55)}
.row dd{font:.95rem/1.55 var(--sans);color:rgba(17,17,17,.92)}
.narrative{padding:0 0 1.5rem}
.narrative .section-kicker{color:rgba(255,255,255,.42)}
.narrative-body{max-width:68ch;font:1rem/1.9 var(--sans);color:#f1ece3}
.narrative-body :global(p){margin-bottom:1.2rem}
.relation-list,.support{display:grid;gap:1rem}
.relation-item{padding-top:.75rem;border-top:1px solid var(--paper-line)}
.relation-label{font:.72rem/1.2 var(--mono);letter-spacing:.08em;text-transform:uppercase;color:rgba(17,17,17,.55);margin-bottom:.35rem}
.relation-target{font:600 1rem/1.4 var(--sans);color:var(--ink)}
.relation-target:hover{color:var(--pulse);text-decoration:underline}
.relation-target.static{display:inline-block}
.relation-notes{margin-top:.2rem;font:.86rem/1.5 var(--sans);color:rgba(17,17,17,.62)}
.support-block + .support-block{padding-top:.25rem;border-top:1px solid var(--paper-line)}
.support-list{display:grid;gap:.75rem}
.support-row{display:grid;grid-template-columns:180px 1fr;gap:.75rem;font:.92rem/1.5 var(--sans)}
.support-row span{color:rgba(17,17,17,.65)}
.support-row strong{color:var(--ink)}
.support-row-stack{display:flex;flex-direction:column;gap:.15rem}
.support-row-stack a{color:var(--ink)}
.gallery{padding-top:.5rem}
.gallery .section-kicker{color:rgba(255,255,255,.42)}
.gallery-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.5rem}
.gallery-item{margin:0}
.gallery-item.hero{grid-column:1 / -1}
.gallery-item img{display:block;width:100%;height:auto;background:#111}
.gallery-item figcaption{padding:.5rem 0 0;font:.72rem/1.5 var(--mono);color:rgba(255,255,255,.5)}
.archive-nav{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem;padding-top:1.5rem;border-top:1px solid var(--line);margin-top:1.5rem}
.archive-nav-item{display:flex;flex-direction:column;gap:.25rem;padding:.85rem .95rem;border:1px solid rgba(255,255,255,.12);color:#f1ece3}
.archive-nav-item:hover{border-color:var(--pulse);background:rgba(255,255,255,.03)}
.archive-nav-label{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.42)}
.archive-nav-item strong{font:600 .98rem/1.4 var(--sans);letter-spacing:-.02em}
@media (min-width: 900px){
  .obra-page{padding:1.5rem 2rem 4rem}
  .obra-entry{padding-bottom:2.5rem;margin-bottom:2rem}
  .panel{max-width:980px;padding:1.25rem 1.25rem 1.35rem}
  .support{grid-template-columns:repeat(3,minmax(0,1fr));align-items:start}
  .support-block + .support-block{border-top:none;padding-top:0;padding-left:1rem;border-left:1px solid var(--paper-line)}
}
@media (max-width: 720px){
  .row,.support-row{grid-template-columns:1fr;gap:.25rem}
  .gallery-grid,.archive-nav{grid-template-columns:1fr}
}
</style>
