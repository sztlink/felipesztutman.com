---
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  lang?: 'pt' | 'en';
  schemaType?: 'WebSite' | 'Person' | 'ArtWork';
  schemaName?: string;
  schemaDate?: string;
  schemaLocation?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  fullBleed?: boolean;
  bodyClass?: string;
}
const {
  title,
  description = 'Felipe Sztutman — artista e construtor de sistemas imersivos. São Paulo, Brasil.',
  ogTitle,
  ogImage,
  lang = 'pt',
  schemaType = 'WebSite',
  schemaName,
  schemaDate,
  schemaLocation,
  showHeader = true,
  showFooter = true,
  fullBleed = false,
  bodyClass = ''
} = Astro.props;
const isEN = lang === 'en';
const prefix = isEN ? '/en' : '';
const altLang = isEN ? 'pt' : 'en';
const currentPath = Astro.url.pathname;
const altPath = isEN ? currentPath.replace(/^\/en/, '') || '/' : `/en${currentPath}`;
---
<!DOCTYPE html>
<html lang={isEN ? 'en' : 'pt-BR'}>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="google-site-verification" content="xCTUYty7QcTp9Ulg-oZZKpfgJuioxsAcHKXyPp7XBj4" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={Astro.url.href}>
<link rel="alternate" hrefLang="pt-BR" href={`https://felipesztutman.com${isEN ? currentPath.replace(/^\/en/, '') || '/' : currentPath}`}>
<link rel="alternate" hrefLang="en" href={`https://felipesztutman.com${isEN ? currentPath : '/en' + currentPath}`}>
<meta property="og:title" content={ogTitle || title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={Astro.url.href}>
<meta property="og:type" content="website">
<meta property="og:locale" content="pt_BR">
{ogImage && <meta property="og:image" content={`https://felipesztutman.com${ogImage}`} />}
{ogImage && <meta name="twitter:image" content={`https://felipesztutman.com${ogImage}`} />}
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'}>
<meta name="twitter:title" content={ogTitle || title}>
<meta name="twitter:description" content={description}>
<SchemaOrg type={schemaType} name={schemaName} description={description} url={Astro.url.href} dateCreated={schemaDate} location={schemaLocation} />
<style is:global>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#060810;--fg:#c8d0e0;--fg2:rgba(200,210,230,.45);--fg3:rgba(200,210,230,.2);--accent:#4477ff;--mono:'SF Mono','Fira Code','Fira Mono','Roboto Mono',monospace;--sans:system-ui,-apple-system,'Segoe UI',sans-serif}
html{background:var(--bg);color:var(--fg);font-family:var(--sans);font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased}
body{max-width:720px;margin:0 auto;padding:2rem 1.5rem 4rem;background:var(--bg);color:var(--fg)}
body.full-bleed{max-width:none;margin:0;padding:0}
a{color:var(--accent);text-decoration:none}a:hover{text-decoration:underline}
header{margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(255,255,255,.06)}
header h1{font:500 1.3rem/1.2 var(--sans);letter-spacing:-.02em}
header h1 a{color:var(--fg);text-decoration:none}header h1 a:hover{color:var(--accent)}
header nav{margin-top:.75rem;font:.75rem/1 var(--mono);color:var(--fg3);display:flex;gap:1.2rem;flex-wrap:wrap}
header nav a{color:var(--fg2);transition:color .15s}header nav a:hover{color:var(--fg)}
footer{margin-top:3rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,.04);font:.7rem/1.6 var(--mono);color:var(--fg3)}
@media(max-width:600px){body{padding:1.5rem 1rem 3rem}body.full-bleed{padding:0}header h1{font-size:1.1rem}}
</style>
</head>
<body class:list={[bodyClass, fullBleed && 'full-bleed']}>
{showHeader && (
<header>
  <h1><a href={`${prefix}/`}>Felipe Sztutman</a></h1>
  <nav>
    <a href="/mapa">{isEN ? 'map' : 'mapa'}</a>
    <a href={`${prefix}/#obras`}>{isEN ? 'works' : 'obras'}</a>
    <a href={`${prefix}/escritos`}>{isEN ? 'writings' : 'escritos'}</a>
    <a href={`${prefix}/publicacoes`}>{isEN ? 'publications' : 'publicações'}</a>
    <a href={`${prefix}/trajetoria`}>{isEN ? 'trajectory' : 'trajetória'}</a>
    <a href={`${prefix}/sobre`}>{isEN ? 'about' : 'sobre'}</a>
    <a href={`${prefix}/#contato`}>{isEN ? 'contact' : 'contato'}</a>
    <a href="/grafo.html">grafo ↗</a>
    <a href={altPath} class="lang-toggle">{altLang.toUpperCase()}</a>
  </nav>
</header>
)}
<slot />
{showFooter && (
<footer>
  <p>Felipe Sztutman · São Paulo · 2009–2026</p>
  <p style="margin-top:.5rem"><a href="https://enciclopedia.itaucultural.org.br/pessoas/60193-felipe-sztutman" target="_blank">Enciclopédia Itaú Cultural</a></p>
</footer>
)}
</body>
</html>
