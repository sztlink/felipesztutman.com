---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    date?: string;
    description?: string;
    lang?: 'pt' | 'en';
    type?: string;
  };
}

const { frontmatter } = Astro.props;
const lang = frontmatter.lang || 'pt';
const isEN = lang === 'en';
const prefix = isEN ? '/en' : '';
const seoTitle = `Felipe Sztutman — ${frontmatter.title}`;
const seoDesc = frontmatter.description || `${frontmatter.title}. Felipe Sztutman.`;
---
<Base title={seoTitle} description={seoDesc} lang={lang}>
  <article class="escrito">
    <a href={`${prefix}/escritos`} class="back">{isEN ? '← writings' : '← escritos'}</a>
    
    {frontmatter.type && <div class="escrito-type">{frontmatter.type}</div>}
    <h1 class="escrito-title">{frontmatter.title}</h1>
    {frontmatter.subtitle && <div class="escrito-subtitle">{frontmatter.subtitle}</div>}
    {frontmatter.date && <div class="escrito-date">{frontmatter.date}</div>}

    <div class="escrito-body">
      <slot />
    </div>
  </article>
</Base>

<style>
.back{font:.75rem/1 var(--mono);color:var(--fg3);display:inline-block;margin-bottom:1.5rem;transition:color .15s}
.back:hover{color:var(--fg);text-decoration:none}
.escrito-type{font:.7rem/1 var(--mono);text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin-bottom:.5rem}
.escrito-title{font:500 2rem/1.2 var(--sans);letter-spacing:-.03em;margin-bottom:.35rem}
.escrito-subtitle{font:400 1.1rem/1.4 var(--sans);color:var(--fg2);margin-bottom:.35rem}
.escrito-date{font:.75rem/1 var(--mono);color:var(--fg3);margin-bottom:2.5rem}
.escrito-body{font:1rem/1.9 var(--sans);color:var(--fg)}
.escrito-body :global(p){margin-bottom:1.4rem}
.escrito-body :global(h2){font:500 1.3rem/1.3 var(--sans);margin:2.5rem 0 1rem;letter-spacing:-.02em}
.escrito-body :global(h3){font:500 1rem/1.3 var(--sans);margin:2rem 0 .8rem}
.escrito-body :global(blockquote){border-left:2px solid rgba(68,119,255,.3);padding-left:1.2rem;margin:1.5rem 0;color:var(--fg2);font-style:italic}
.escrito-body :global(em){color:var(--fg2)}
.escrito-body :global(strong){color:var(--fg);font-weight:500}
.escrito-body :global(code){font:var(--mono);font-size:.85em;background:rgba(255,255,255,.05);padding:.15em .4em;border-radius:3px}
.escrito-body :global(hr){border:none;border-top:1px solid rgba(255,255,255,.06);margin:2.5rem 0}
@media(max-width:600px){.escrito-title{font-size:1.5rem}}
</style>
