---
import Base from './Base.astro';
import galleryData from '../data/gallery.json';
type GalleryItem = { src: string; caption: string | null };

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    date?: string;
    description?: string;
    lang?: 'pt' | 'en';
    type?: string;
  };
}

const { frontmatter } = Astro.props;
const lang = frontmatter.lang || 'pt';
const isEN = lang === 'en';
const prefix = isEN ? '/en' : '';
const seoTitle = `Felipe Sztutman — ${frontmatter.title}`;
const seoDesc = frontmatter.description || `${frontmatter.title}. Felipe Sztutman.`;
const slug = Astro.url.pathname.replace(/^\/(?:en\/)?escritos\//, '').replace(/\/$/, '');
const items: GalleryItem[] = (galleryData as Record<string, GalleryItem[]>)[slug] || [];
const heroItem = items[0] || null;
const galleryItems = items.slice(1);
const ogImage = heroItem?.src || undefined;
const altPath = isEN ? `/escritos/${slug}` : `/en/escritos/${slug}`;
---
<Base
  title={seoTitle}
  description={seoDesc}
  lang={lang}
  ogImage={ogImage}
  fullBleed={true}
  showHeader={false}
  showFooter={false}
  bodyClass="page-escrito"
>
  <main class="writing-page">
    <section class="writing-entry">
      <div class="surface-links">
        <a href={`${prefix}/escritos`} class="back">{isEN ? '← writings' : '← escritos'}</a>
        <a href={`${prefix}/#obras`} class="surface-link">{isEN ? 'archive' : 'arquivo'}</a>
        <a href={isEN ? '/mapa' : '/mapa'} class="surface-link">{isEN ? 'relational map' : 'mapa relacional'}</a>
        <a href={altPath} class="surface-link">{isEN ? 'PT' : 'EN'}</a>
      </div>
      {frontmatter.type && <div class="writing-type">{frontmatter.type}</div>}
      <h1>{frontmatter.title}</h1>
      {frontmatter.subtitle && <p class="writing-subtitle">{frontmatter.subtitle}</p>}
      {frontmatter.date && <div class="writing-date">{frontmatter.date}</div>}
    </section>

    <article class="paper" aria-label={frontmatter.title}>
      {heroItem && (
        <figure class="writing-hero">
          <img src={heroItem.src} alt={frontmatter.title} loading="eager" data-idx="0" class="lightbox-trigger" />
          {heroItem.caption && <figcaption>{heroItem.caption}</figcaption>}
        </figure>
      )}

      <div class="writing-body">
        <slot />
      </div>

      {galleryItems.length > 0 && (
        <div class="writing-gallery" aria-label={isEN ? 'Image documentation' : 'Documentação de imagem'}>
          {galleryItems.map((item, i) => (
            <figure class="gallery-fig">
              <img src={item.src} alt={`${frontmatter.title} — ${i + 2}`} loading="lazy" data-idx={i + 1} class="lightbox-trigger" />
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )}
    </article>
  </main>

  <div id="lightbox" aria-hidden="true">
    <button id="lb-close" aria-label={isEN ? 'Close' : 'Fechar'}>×</button>
    <div id="lb-nav"><button class="lb-arrow" id="lb-prev" aria-label={isEN ? 'Previous' : 'Anterior'}>←</button><button class="lb-arrow" id="lb-next" aria-label={isEN ? 'Next' : 'Próxima'}>→</button></div>
    <img id="lb-img" src="" alt="" />
    <div id="lb-caption"></div>
    <div id="lb-counter"></div>
  </div>

  <script is:inline define:vars={{ items: JSON.stringify(items) }}>
    (function() {
      const gallery = JSON.parse(items);
      if (!gallery.length) return;
      const lb = document.getElementById('lightbox');
      const lbImg = document.getElementById('lb-img');
      const lbCap = document.getElementById('lb-caption');
      const lbCount = document.getElementById('lb-counter');
      let current = 0;
      function show(idx) {
        current = idx;
        const item = gallery[idx];
        if (!item) return;
        lbImg.src = item.src;
        lbCap.textContent = item.caption || '';
        lbCount.textContent = (idx + 1) + ' / ' + gallery.length;
        lb.classList.add('open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function hide() {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      function next() { show((current + 1) % gallery.length); }
      function prev() { show((current - 1 + gallery.length) % gallery.length); }
      document.querySelectorAll('.lightbox-trigger').forEach(function(img) {
        img.addEventListener('click', function() { show(parseInt(img.dataset.idx || '0')); });
      });
      document.getElementById('lb-close').addEventListener('click', hide);
      document.getElementById('lb-prev').addEventListener('click', prev);
      document.getElementById('lb-next').addEventListener('click', next);
      lb.addEventListener('click', function(e) { if (e.target === lb) hide(); });
      document.addEventListener('keydown', function(e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') hide();
        if (e.key === 'ArrowRight') next();
        if (e.key === 'ArrowLeft') prev();
      });
      var touchX = 0;
      lb.addEventListener('touchstart', function(e) { touchX = e.touches[0].clientX; });
      lb.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 50) { dx > 0 ? prev() : next(); }
      });
    })();
  </script>
</Base>

<style is:global>
body.page-escrito{background:#050505;color:#f1ece3}
body.page-escrito a{text-decoration:none}
</style>

<style>
:root{--paper:#ece5d8;--ink:#111111;--line:rgba(17,17,17,.16);--muted:rgba(17,17,17,.58)}
.writing-page{min-height:100vh;background:#050505}
.writing-entry{padding:1.25rem 1rem 3rem;border-bottom:1px solid rgba(255,255,255,.08)}
.surface-links{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem}
.back,.surface-link,.writing-type,.writing-date{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase}
.back,.surface-link{display:inline-block;color:rgba(255,255,255,.55)}
.back:hover,.surface-link:hover{color:#fff;text-decoration:none}
.surface-link{color:rgba(255,255,255,.38)}
.writing-type{color:rgba(255,255,255,.48);margin-bottom:.75rem}
.writing-entry h1{font:900 clamp(2.6rem,8vw,6.6rem)/.9 var(--sans);letter-spacing:-.06em;margin-bottom:.85rem;max-width:13ch;color:#f1ece3}
.writing-subtitle{max-width:48rem;font:1.05rem/1.65 var(--sans);color:rgba(255,255,255,.7);margin:0 0 .9rem}
.writing-date{color:rgba(255,255,255,.42)}
.paper{background:var(--paper);color:var(--ink);padding:1rem 1rem 3rem;min-height:56vh}
.writing-hero{margin:0 0 2rem;border-bottom:1px solid var(--line);padding-bottom:.75rem}
.writing-hero img{width:100%;height:auto;display:block;cursor:pointer}
.writing-hero figcaption,.gallery-fig figcaption{font:.68rem/1.45 var(--mono);letter-spacing:.04em;color:var(--muted);margin-top:.5rem}
.writing-body{font:1.05rem/1.85 Georgia,'Times New Roman',serif;max-width:780px;color:var(--ink)}
.writing-body :global(p){margin-bottom:1.35rem}
.writing-body :global(h2){font:800 clamp(1.45rem,3vw,2.15rem)/1.08 var(--sans);letter-spacing:-.04em;margin:2.8rem 0 1rem;color:var(--ink)}
.writing-body :global(h3){font:700 1.05rem/1.25 var(--sans);letter-spacing:-.02em;margin:2rem 0 .75rem;color:var(--ink)}
.writing-body :global(ul),.writing-body :global(ol){padding-left:1.25rem;margin:0 0 1.35rem}
.writing-body :global(li){margin:.35rem 0}
.writing-body :global(blockquote){border-left:2px solid rgba(17,17,17,.28);padding-left:1rem;margin:1.75rem 0;color:rgba(17,17,17,.68);font-style:italic}
.writing-body :global(em){color:rgba(17,17,17,.7)}
.writing-body :global(strong){color:var(--ink);font-weight:700}
.writing-body :global(a){color:#111;border-bottom:1px solid rgba(17,17,17,.32)}
.writing-body :global(a:hover){border-color:#111;text-decoration:none}
.writing-body :global(code){font-family:var(--mono);font-size:.85em;background:rgba(17,17,17,.08);padding:.15em .4em;border-radius:2px}
.writing-body :global(pre){background:rgba(17,17,17,.08);padding:1rem;overflow:auto;margin:1.5rem 0;font:.82rem/1.55 var(--mono)}
.writing-body :global(hr){border:none;border-top:1px solid var(--line);margin:2.5rem 0}
.writing-gallery{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:3rem 0 0;max-width:980px}
.gallery-fig{margin:0;border-top:1px solid var(--line);padding-top:.5rem}
.writing-gallery img{width:100%;height:auto;display:block;cursor:pointer;transition:opacity .15s}
.writing-gallery img:hover,.writing-hero img:hover{opacity:.9}
.lightbox-trigger{cursor:pointer}
#lightbox{position:fixed;inset:0;background:rgba(4,6,14,.96);z-index:100;display:none;align-items:center;justify-content:center;flex-direction:column}
#lightbox.open{display:flex}
#lb-img{max-width:92vw;max-height:82vh;object-fit:contain}
#lb-caption{font:.75rem/1.6 var(--mono);color:rgba(255,255,255,.45);margin-top:.75rem;text-align:center;max-width:680px;padding:0 1rem}
#lb-close{position:fixed;top:14px;right:18px;font:1.2rem/1 var(--mono);color:rgba(255,255,255,.45);cursor:pointer;z-index:101;background:transparent;border:0}
#lb-close:hover{color:#fff}
#lb-nav{position:fixed;top:50%;width:100%;display:flex;justify-content:space-between;padding:0 12px;transform:translateY(-50%);pointer-events:none;z-index:101}
.lb-arrow{font:1.5rem/1 var(--mono);color:rgba(255,255,255,.45);cursor:pointer;pointer-events:auto;padding:8px;user-select:none;background:transparent;border:0}
.lb-arrow:hover{color:#fff}
#lb-counter{position:fixed;bottom:14px;right:18px;font:.7rem/1 var(--mono);color:rgba(255,255,255,.45);z-index:101}
@media (min-width: 900px){.writing-entry,.paper{padding-left:2rem;padding-right:2rem}.writing-entry{padding-top:1.5rem;padding-bottom:3.5rem}.paper{padding-bottom:4rem}.writing-body{font-size:1.12rem}}
@media (max-width: 720px){.writing-entry h1{font-size:clamp(2.4rem,14vw,4rem)}.writing-gallery{grid-template-columns:1fr}.writing-body{font-size:1rem;line-height:1.78}}
</style>
