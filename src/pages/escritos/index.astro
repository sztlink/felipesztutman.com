---
import Base from '../../layouts/Base.astro';

const modules = import.meta.glob('./*.md', { eager: true }) as Record<string, any>;
const escritos = Object.entries(modules)
  .map(([path, mod]) => ({
    slug: path.split('/').pop()!.replace('.md', ''),
    title: mod.frontmatter.title as string,
    type: mod.frontmatter.type as string,
    desc: mod.frontmatter.description as string,
    date: (mod.frontmatter.date || '') as string,
  }))
  .sort((a, b) => a.title.localeCompare(b.title, 'pt-BR'));
---
<Base
  title="Felipe Sztutman — Escritos"
  description="Textos sobre prática artística, cartografia do saber, implante cognitivo szt.link e pesquisa."
  fullBleed={true}
  showHeader={false}
  showFooter={false}
  bodyClass="page-escritos"
>
  <main class="archive-page">
    <section class="entry">
      <a href="/#obras" class="back">← arquivo</a>
      <div class="entry-kicker">ESCRITOS</div>
      <h1>Processo, sistema, pesquisa</h1>
      <p>Textos que emergem da prática. Não documentação neutra, mas elaboração conceitual que acompanha e dobra a obra.</p>
    </section>

    <section class="paper">
      <div class="paper-kicker">ARQUIVO DE ESCRITOS</div>
      <div class="count">{escritos.length} escrito{escritos.length === 1 ? '' : 's'}</div>
      <div class="writing-list">
        {escritos.map((item) => (
          <a href={`/escritos/${item.slug}`} class="writing-item">
            <div class="writing-type">{item.type}</div>
            <div class="writing-main">
              <div class="writing-title">{item.title}</div>
              {item.date && <div class="writing-date">{item.date}</div>}
              <div class="writing-desc">{item.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Base>

<style is:global>
body.page-escritos{background:#050505;color:#f1ece3}
body.page-escritos a{text-decoration:none}
</style>

<style>
:root{--paper:#ece5d8;--ink:#111111;--line:rgba(17,17,17,.16)}
.archive-page{min-height:100vh;background:#050505}
.entry{padding:1.25rem 1rem 3rem;border-bottom:1px solid rgba(255,255,255,.08)}
.back,.entry-kicker,.paper-kicker,.count,.writing-type,.writing-date{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase}
.back{display:inline-block;color:rgba(255,255,255,.55);margin-bottom:1rem}.back:hover{color:#fff}
.entry-kicker{color:rgba(255,255,255,.48);margin-bottom:.75rem}
.entry h1{font:900 clamp(2.8rem,8vw,6rem)/.94 var(--sans);letter-spacing:-.05em;margin-bottom:.85rem;max-width:12ch}
.entry p{max-width:46rem;font:1rem/1.65 var(--sans);color:rgba(255,255,255,.7)}
.paper{background:var(--paper);color:var(--ink);padding:1rem 1rem 2rem}
.paper-kicker{color:rgba(17,17,17,.45);margin-bottom:.75rem}
.count{color:rgba(17,17,17,.58);margin-bottom:1rem}
.writing-list{border-top:1px solid var(--line)}
.writing-item{display:grid;grid-template-columns:120px 1fr;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--line);color:inherit}
.writing-item:hover .writing-title{text-decoration:underline}
.writing-type{color:rgba(17,17,17,.5);padding-top:.15rem}
.writing-title{font:600 1.08rem/1.3 var(--sans);letter-spacing:-.02em;margin-bottom:.2rem}
.writing-date{color:rgba(17,17,17,.48);margin-bottom:.35rem}
.writing-desc{font:.9rem/1.65 var(--sans);color:rgba(17,17,17,.72);max-width:56ch}
@media (min-width: 900px){.entry,.paper{padding-left:2rem;padding-right:2rem}.entry{padding-top:1.5rem;padding-bottom:3.5rem}.paper{padding-bottom:2.5rem}}
@media (max-width: 720px){.writing-item{grid-template-columns:1fr;gap:.4rem}}
</style>
