---
import Base from '../../layouts/Base.astro';

const escritos = [
  { slug: 'szt-link', title: 'szt.link', type: 'sistema', desc: 'Implante cognitivo do artista. Argila computacional moldada como extensão do processo criativo.' },
  { slug: 'cartografia-do-saber', title: 'Cartografia do Saber', type: 'método', desc: 'Técnica de conceptualização derivada da obra de Suely Rolnik. Parte do corpo antes da razão, das forças antes das formas.' },
  { slug: 'borda-difusa', title: 'Cartografia: Borda Difusa', type: 'cartografia', desc: 'Sessão fundacional do szt.link. O agente deixou de ser ferramenta e foi nomeado como implante cognitivo.' },
  { slug: 'luzcidade', title: 'LUZCIDADE', type: 'pesquisa', desc: 'TCC Design FAU-USP. A linhagem de Moholy-Nagy a Dan Flavin, de Flavin à luz no espaço público de São Paulo.' },
];
---
<Base title="Felipe Sztutman — Escritos" description="Textos sobre prática artística, cartografia do saber, implante cognitivo szt.link, e pesquisa acadêmica. Felipe Sztutman.">

<a href="/" class="back">← início</a>
<h1 class="page-title">Escritos</h1>
<p class="page-intro">Textos sobre processo, método, sistema e pesquisa. Material que emerge da prática artística e da elaboração conceitual — não separados, mas imbricados.</p>

<div class="escritos-list">
  {escritos.map(e => (
    <a href={`/escritos/${e.slug}`} class="escrito-link">
      <div class="escrito-card">
        <div class="escrito-type-tag">{e.type}</div>
        <div class="escrito-card-title">{e.title}</div>
        <div class="escrito-card-desc">{e.desc}</div>
      </div>
    </a>
  ))}
</div>

</Base>

<style>
.back{font:.75rem/1 var(--mono);color:var(--fg3);display:inline-block;margin-bottom:1.5rem;transition:color .15s}
.back:hover{color:var(--fg);text-decoration:none}
.page-title{font:500 2rem/1.15 var(--sans);letter-spacing:-.03em;margin-bottom:.75rem}
.page-intro{font:.95rem/1.7 var(--sans);color:var(--fg2);margin-bottom:2.5rem}
.escritos-list{display:flex;flex-direction:column;gap:1.5rem}
.escrito-link{text-decoration:none;display:block}
.escrito-link:hover .escrito-card-title{color:var(--accent)}
.escrito-card{padding:1.2rem 0;border-bottom:1px solid rgba(255,255,255,.04)}
.escrito-type-tag{font:.65rem/1 var(--mono);text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin-bottom:.5rem}
.escrito-card-title{font:500 1.15rem/1.3 var(--sans);color:var(--fg);transition:color .15s;margin-bottom:.3rem}
.escrito-card-desc{font:.88rem/1.6 var(--sans);color:var(--fg2)}
</style>
