---
import Base from '../../layouts/Base.astro';

const items = [
  {
    slug: '100-anos-de-arte-moderna',
    title: '100 Anos de Arte Moderna: a cena contemporânea',
    meta: 'Carlos Zibel Costa · print publication',
    desc: 'Book that dedicates pages 64–67 to Felipe Sztutman’s trajectory, linking Cachoeira, sem título, para Mantiqueira, and OCEANVS within a single lineage.'
  }
];
---
<Base title="Felipe Sztutman — Publications" description="Publications, books, and editorial records related to Felipe Sztutman’s trajectory." lang="en">

<a href="/en" class="back">← home</a>
<h1 class="page-title">Publications</h1>

<div class="intro">
  <p>Not every inscription of a trajectory appears as press coverage. Some works circulate through books, catalogues, and institutional publications. This section gathers those records when they become part of the work’s field.</p>
</div>

<section>
  {items.map(item => (
    <a href={`/en/publicacoes/${item.slug}`} class="entry-link">
      <div class="entry">
        <div class="entry-title">{item.title}</div>
        <div class="entry-meta">{item.meta}</div>
        <div class="entry-desc">{item.desc}</div>
      </div>
    </a>
  ))}
</section>

</Base>

<style>
.back{font:.75rem/1 var(--mono);color:var(--fg3);display:inline-block;margin-bottom:1.5rem;transition:color .15s}
.back:hover{color:var(--fg);text-decoration:none}
.page-title{font:500 2rem/1.15 var(--sans);letter-spacing:-.03em;margin-bottom:2rem}
.intro{font:.98rem/1.85 var(--sans);margin-bottom:2rem;color:var(--fg)}
.entry-link{text-decoration:none;display:block}
.entry-link:hover .entry-title{color:var(--accent)}
.entry{margin-bottom:1.5rem}
.entry-title{font:500 1rem/1.3 var(--sans);color:var(--fg);transition:color .15s;margin-bottom:.15rem}
.entry-meta{font:.75rem/1.4 var(--mono);color:var(--fg3);margin-bottom:.35rem}
.entry-desc{font:.88rem/1.7 var(--sans);color:var(--fg2)}
</style>
