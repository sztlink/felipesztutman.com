---
import Base from '../../layouts/Base.astro';

const obras = [
  { slug: 'player1', title: 'Player 1 — 50 Years of Video Games', year: '2026', location: 'Farol Santander, São Paulo', desc: 'Exhibition under confirmation: proposed body-interface experiences and video game archive.' },
  { slug: 'flama', title: 'FLAMA', year: '2026', location: 'Farol Santander, São Paulo', desc: 'Fire. Sculptural bonfire, interactive room, Crystal Chamber.' },
  { slug: 'amano', title: 'AMANO — Beyond Fantasy', year: '2024–26', location: 'CCBB SP, BH, Rio', desc: 'Largest Yoshitaka Amano exhibition in the world. Immersive space with 15 laser projectors.' },
  { slug: 'floresta-utopica', title: 'Floresta Utópica', year: '2025', location: 'Farol Santander, São Paulo', desc: 'Seven acts, twenty minutes. Mapped projection, mirrors, scents, light sculpture.' },
  { slug: 'o-que-nos-une', title: 'O Que Nos Une', year: '2025', location: 'Centro Cultural FIESP, São Paulo', desc: 'Nicolelis\' neuroscience translated into immersive experience.' },
  { slug: 'andromeda', title: 'Andrômeda — Endless Universe', year: '2025', location: 'Farol Santander, São Paulo', desc: 'Cosmos (interactive) + Andrômeda (immersive, 17 min).' },
  { slug: 'luz-aeterna', title: 'Luz Æterna — Essay on the Sun', year: '2024', location: 'CCBB Brasília and BH', desc: 'Eight Brazilian artists. I designed the exhibition space.' },
  { slug: 'sao-paulo-3024', title: 'São Paulo 3024', year: '2024', location: 'Farol Santander, São Paulo', desc: 'São Paulo a thousand years from now. LLMs, LoRa, OpenCV. 7 acts, 16 min.' },
  { slug: 'metadata', title: 'METADATA — The Invisible World', year: '2023–24', location: 'SESI/FIESP, São Paulo', desc: 'Real-time São Paulo data translated into 3D fluids.' },
  { slug: 'oceanvs', title: 'OCEANVS — Immersion in Blue', year: '2022–26', location: 'Farol Santander SP, Casa Fiat BH', desc: 'Eight acts about water. National touring.' },
  { slug: 'mementos', title: 'Mementos', year: '2019', location: 'Farol Santander, São Paulo', desc: '45 lasers and a large crystal. Generative patterns.' },
  { slug: 'interludio', title: 'Interlúdio', year: '2019', location: 'Farol Santander, São Paulo', desc: 'Sensors and responsive light. The work only exists with human presence.' },
];

const luzcidade = [
  { slug: 'objeto-em-forma-de-espaco', title: 'Objeto em Forma de: Espaço', year: '2009', location: 'LabMIS, MIS-SP' },
  { slug: 'occupycopan', title: 'OccupyCopan', year: '2011', location: 'Edifício Copan, São Paulo' },
  { slug: 'cachoeira', title: 'Cachoeira, para Córrego das Almas', year: '2012', location: 'Vale do Anhangabaú, URBE/CCBB' },
  { slug: 'canvas13', title: 'sem título, para Canvas #13', year: '2013', location: 'Serralheria Cultural, São Paulo' },
  { slug: 'corrego-rio-verde', title: 'sem título, para Córrego Rio Verde', year: '2013', location: 'Beco do Batman, Vila Madalena' },
  { slug: 'mantiqueira', title: 'sem título, para Mantiqueira', year: '2013', location: 'Serra da Mantiqueira' },
];
---
<Base title="Felipe Sztutman — Artist, Immersive Systems, São Paulo" description="Felipe Sztutman is an artist and builder of immersive systems. He conceives environments where light, technology, and perception become language. São Paulo, Brazil." lang="en">

<div class="statement">
  <p>In 2012, I was invited to create a public artwork in downtown São Paulo. I chose to reveal something invisible: the Córrego das Almas, a stream that runs hidden beneath the pavement of Vale do Anhangabaú. With electroluminescent cables, I conceived the work <em>Cachoeira</em>, highlighting how we try to control and even conceal the rivers that sustain our cities.</p>
  <p>Thirteen years later, this same impulse — making the invisible visible — continues to guide my work. I design immersive spaces where light, sound, technology, and perception organize themselves as systems. I don't make objects to be observed from outside. I conceive environments that only exist when someone enters.</p>
</div>

<section id="obras">
  <h2>Works</h2>
  {obras.map(o => (
    <a href={`/en/obras/${o.slug}`} class="work-link">
      <div class="work">
        <div class="work-title">{o.title}</div>
        <div class="work-meta">{o.year} · {o.location}</div>
        <div class="work-desc">{o.desc}</div>
      </div>
    </a>
  ))}

  <div class="series">
    <div class="series-label">LUZCIDADE Series · Design Thesis FAU-USP · 2009–2013</div>
    {luzcidade.map(o => (
      <a href={`/en/obras/${o.slug}`} class="work-link">
        <div class="work work-series">
          <div class="work-title">{o.title}</div>
          <div class="work-meta">{o.year} · {o.location}</div>
        </div>
      </a>
    ))}
  </div>
</section>

<section id="contato">
  <h2>Contact</h2>
  <div class="links">
    <a href="mailto:felipe@aya.cx">felipe@aya.cx</a>
    <a href="https://instagram.com/felipesztutman" target="_blank">instagram</a>
    <a href="https://aya.cx" target="_blank">aya.cx</a>
    <a href="https://br.linkedin.com/in/felipesztutman" target="_blank">linkedin</a>
  </div>
</section>

</Base>

<style>
.statement{margin-bottom:3rem;font-size:1.05rem;line-height:1.85}
.statement p{margin-bottom:1.2rem}
section{margin-bottom:3rem}
section h2{font:.7rem/1 var(--mono);text-transform:uppercase;letter-spacing:.12em;color:var(--fg3);margin-bottom:1.2rem;padding-bottom:.5rem;border-bottom:1px solid rgba(255,255,255,.04)}
.work-link{text-decoration:none;display:block}
.work-link:hover .work-title{color:var(--accent)}
.work{margin-bottom:1.5rem}
.work-title{font:500 1rem/1.3 var(--sans);color:var(--fg);transition:color .15s;margin-bottom:.15rem}
.work-meta{font:.75rem/1.4 var(--mono);color:var(--fg3);margin-bottom:.3rem}
.work-desc{font:.88rem/1.65 var(--sans);color:var(--fg2)}
.series{margin-top:2rem;padding-left:1.5rem;border-left:1px solid rgba(255,255,255,.06)}
.series-label{font:.7rem/1 var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--fg3);margin-bottom:1rem}
.work-series{margin-bottom:1rem}
.links{font:.75rem/1 var(--mono);color:var(--fg3);display:flex;gap:1.2rem;flex-wrap:wrap}
.links a{color:var(--fg2);transition:color .15s}.links a:hover{color:var(--fg)}
</style>
