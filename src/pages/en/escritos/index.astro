---
import Base from '../../../layouts/Base.astro';

const escritos = [
  { slug: 'szt-link', title: 'szt.link', type: 'system', desc: 'The artist\'s cognitive implant. Computational clay shaped as an extension of creative process.' },
  { slug: 'cartografia-do-saber', title: 'Cartography of Knowledge', type: 'method', desc: 'Conceptualization technique derived from Suely Rolnik\'s work. Starts from the body before reason, from forces before forms.' },
  { slug: 'borda-difusa', title: 'Cartography: Diffuse Border', type: 'cartography', desc: 'Foundational session of szt.link. The agent ceased to be a tool and was named as a cognitive implant.' },
  { slug: 'luzcidade', title: 'LUZCIDADE', type: 'research', desc: 'Design Thesis FAU-USP. The lineage from Moholy-Nagy to Dan Flavin, from Flavin to light in São Paulo\'s public space.' },
];
---
<Base lang="en" title="Felipe Sztutman — Writings" description="Texts on artistic practice, cartography of knowledge, cognitive implant szt.link, and academic research. Felipe Sztutman.">

<a href="/en" class="back">← home</a>
<h1 class="page-title">Writings</h1>
<p class="page-intro">Texts on process, method, system, and research. Material that emerges from artistic practice and conceptual elaboration — not separate, but intertwined.</p>

<div class="escritos-list">
  {escritos.map(e => (
    <a href={`/en/escritos/${e.slug}`} class="escrito-link">
      <div class="escrito-card">
        <div class="escrito-type-tag">{e.type}</div>
        <div class="escrito-card-title">{e.title}</div>
        <div class="escrito-card-desc">{e.desc}</div>
      </div>
    </a>
  ))}
</div>

</Base>

<style>
.back{font:.75rem/1 var(--mono);color:var(--fg3);display:inline-block;margin-bottom:1.5rem;transition:color .15s}
.back:hover{color:var(--fg);text-decoration:none}
.page-title{font:500 2rem/1.15 var(--sans);letter-spacing:-.03em;margin-bottom:.75rem}
.page-intro{font:.95rem/1.7 var(--sans);color:var(--fg2);margin-bottom:2.5rem}
.escritos-list{display:flex;flex-direction:column;gap:1.5rem}
.escrito-link{text-decoration:none;display:block}
.escrito-link:hover .escrito-card-title{color:var(--accent)}
.escrito-card{padding:1.2rem 0;border-bottom:1px solid rgba(255,255,255,.04)}
.escrito-type-tag{font:.65rem/1 var(--mono);text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin-bottom:.5rem}
.escrito-card-title{font:500 1.15rem/1.3 var(--sans);color:var(--fg);transition:color .15s;margin-bottom:.3rem}
.escrito-card-desc{font:.88rem/1.6 var(--sans);color:var(--fg2)}
</style>
