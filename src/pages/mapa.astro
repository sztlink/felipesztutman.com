---
import Base from '../layouts/Base.astro';
import worksData from '../data/works.json';
import relationsData from '../data/map-relations.json';
import referencesData from '../data/references.json';
import publicationsData from '../data/publications.json';
import legacyMap from '../data/mapa.json';

const works = (worksData as any).works || [];
const publicRelations = ((relationsData as any).relations || []).filter((relation: any) => relation.visibility === 'PUBLICA' && !relation.requiresConfirmation);
const references = (referencesData as any).references || [];
const publications = (publicationsData as any).publications || [];

const writingModules = import.meta.glob('./escritos/*.md', { eager: true }) as Record<string, any>;
const writings = Object.entries(writingModules)
  .filter(([path]) => !path.endsWith('index.astro'))
  .map(([path, mod]) => {
    const id = path.split('/').pop()!.replace('.md', '');
    return {
      slug: id,
      title: mod.frontmatter.title as string,
      description: mod.frontmatter.description as string,
      href: `/escritos/${id}`,
      lens: (legacyMap as any).nodes?.[id]?.lens || null,
    };
  });

const referenceGhostMap: Record<string, string> = {
  'moholy-nagy': 'moholy',
  'dan-flavin': 'flavin',
  'gurps-cyberpunk': 'gurps'
};

const publicationGhostMap: Record<string, string> = {
  '100-anos-de-arte-moderna': 'zibel-book'
};

function project(point: [number, number]) {
  const [x, y] = point;
  return {
    x: Math.round((x + 380) * 1.2 + 80),
    y: Math.round((y + 340) * 1.05 + 80),
  };
}

const lenses = ['conceito', 'temporal', 'linhagem'];

function lensPositions(source: any) {
  const base = source?.lens || source;
  if (!base?.conceito) return null;
  const fallback = base.conceito;
  return Object.fromEntries(lenses.map((lens) => [lens, project(base[lens] || fallback)]));
}

function resolveNode(kind: string, id: string) {
  const key = `${kind}:${id}`;
  if (kind === 'OBRA') {
    const work = works.find((entry: any) => entry.slug === id);
    const positions = lensPositions(work?.mapa?.lens);
    if (!work || !positions) return null;
    return {
      id,
      key,
      kind,
      label: work.titulo,
      meta: `${work.numero} · ${work.ano}`,
      href: `/obras/${work.slug}`,
      position: positions.conceito,
      positions,
      color: work.corPulso || '#111111',
    };
  }
  if (kind === 'ESCRITO') {
    const writing = writings.find((entry) => entry.slug === id);
    const positions = lensPositions(writing?.lens);
    if (!writing || !positions) return null;
    return {
      id,
      key,
      kind,
      label: writing.title,
      meta: 'escrito',
      href: writing.href,
      position: positions.conceito,
      positions,
      color: '#7a7a7a',
    };
  }
  if (kind === 'REFERENCIA') {
    const reference = references.find((entry: any) => entry.slug === id);
    const ghost = (legacyMap as any).ghosts?.[referenceGhostMap[id]];
    const positions = lensPositions(ghost?.lens);
    if (!reference || !positions) return null;
    return {
      id,
      key,
      kind,
      label: reference.label,
      meta: 'referência',
      href: null,
      position: positions.conceito,
      positions,
      color: '#4a4a4a',
    };
  }
  if (kind === 'PUBLICACAO') {
    const publication = publications.find((entry: any) => entry.slug === id);
    const ghost = (legacyMap as any).ghosts?.[publicationGhostMap[id]];
    const positions = lensPositions(ghost?.lens);
    if (!publication || !positions) return null;
    return {
      id,
      key,
      kind,
      label: publication.titulo,
      meta: 'publicação',
      href: publication.currentPublicPath || '/publicacoes',
      position: positions.conceito,
      positions,
      color: '#4a4a4a',
    };
  }
  return null;
}

const nodeKeys = new Set<string>();
for (const relation of publicRelations) {
  nodeKeys.add(`${relation.sourceKind}:${relation.source}`);
  nodeKeys.add(`${relation.targetKind}:${relation.target}`);
}

const nodes = [...nodeKeys]
  .map((key) => {
    const [kind, id] = key.split(':');
    return resolveNode(kind, id);
  })
  .filter(Boolean);

const nodeIndex = Object.fromEntries(nodes.map((node: any) => [node.key, node]));

const lines = publicRelations
  .map((relation: any) => {
    const source = nodeIndex[`${relation.sourceKind}:${relation.source}`];
    const target = nodeIndex[`${relation.targetKind}:${relation.target}`];
    if (!source || !target) return null;
    return {
      ...relation,
      source,
      target,
      sourceKey: source.key,
      targetKey: target.key,
      midX: Math.round((source.position.x + target.position.x) / 2),
      midY: Math.round((source.position.y + target.position.y) / 2),
    };
  })
  .filter(Boolean);
---
<Base
  title="Felipe Sztutman — Mapa"
  description="Diagrama de relações públicas entre obras, escritos e referências de Felipe Sztutman."
  fullBleed={true}
  showHeader={false}
  showFooter={false}
  bodyClass="page-map"
>
  <main class="map-page">
    <section class="map-head">
      <div class="surface-links">
        <a href="/#obras" class="back">← arquivo</a>
        <a href="/grafo" class="legacy-link">grafo legacy</a>
      </div>
      <div class="map-kicker">MAPA · EXPLORAÇÃO RELACIONAL</div>
      <h1>Relações públicas</h1>
      <p>Leitura relacional do arquivo atual: obras, escritos, referências e publicações conectados apenas quando a relação já se sustenta publicamente.</p>
      <div class="map-meta">{lines.length} relações públicas · {nodes.length} nós públicos · leitura curada do arquivo atual · relações em confirmação ficam fora desta camada.</div>
    </section>

    <section class="map-shell">
      <div class="lens-controls" aria-label="Lentes do mapa">
        <button type="button" data-lens-button="conceito" class="active" aria-pressed="true">conceito</button>
        <button type="button" data-lens-button="temporal" aria-pressed="false">temporal</button>
        <button type="button" data-lens-button="linhagem" aria-pressed="false">linhagem</button>
      </div>
      <div class="map-legend">
        <span><strong>obra</strong> lastro público</span>
        <span><strong>escrito</strong> camada conceitual</span>
        <span><strong>referência</strong> linhagem</span>
        <span><strong>publicação</strong> circulação editorial</span>
        <span><strong>grafo</strong> camada legacy separada</span>
      </div>
      <div class="map-field">
        <svg viewBox="0 0 1180 820" class="map-lines" aria-hidden="true">
          {lines.map((line: any) => (
            <g>
              <line data-line data-source={line.sourceKey} data-target={line.targetKey} x1={line.source.position.x} y1={line.source.position.y} x2={line.target.position.x} y2={line.target.position.y} />
              {line.label && (
                <text data-line-label data-source={line.sourceKey} data-target={line.targetKey} x={line.midX} y={line.midY}>{line.label}</text>
              )}
            </g>
          ))}
        </svg>

        {nodes.map((node: any) => (
          node.href ? (
            <a
              href={node.href}
              class:list={['map-node', node.kind.toLowerCase()]}
              data-node={node.key}
              data-x-conceito={node.positions.conceito.x}
              data-y-conceito={node.positions.conceito.y}
              data-x-temporal={node.positions.temporal.x}
              data-y-temporal={node.positions.temporal.y}
              data-x-linhagem={node.positions.linhagem.x}
              data-y-linhagem={node.positions.linhagem.y}
              style={`left:${node.position.x}px;top:${node.position.y}px;--node-color:${node.color};`}
            >
              <span class="node-label">{node.label}</span>
              <span class="node-meta">{node.meta}</span>
            </a>
          ) : (
            <div
              class:list={['map-node', node.kind.toLowerCase()]}
              data-node={node.key}
              data-x-conceito={node.positions.conceito.x}
              data-y-conceito={node.positions.conceito.y}
              data-x-temporal={node.positions.temporal.x}
              data-y-temporal={node.positions.temporal.y}
              data-x-linhagem={node.positions.linhagem.x}
              data-y-linhagem={node.positions.linhagem.y}
              style={`left:${node.position.x}px;top:${node.position.y}px;--node-color:${node.color};`}
            >
              <span class="node-label">{node.label}</span>
              <span class="node-meta">{node.meta}</span>
            </div>
          )
        ))}
      </div>
    </section>
  </main>
</Base>

<script>
const nodeElements = Array.from(document.querySelectorAll<HTMLElement>('[data-node]'));
const nodesByKey = new Map(nodeElements.map((node) => [node.dataset.node!, node]));
const lineElements = Array.from(document.querySelectorAll<SVGLineElement>('[data-line]'));
const lineLabels = Array.from(document.querySelectorAll<SVGTextElement>('[data-line-label]'));
const lensButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-lens-button]'));

function pointFor(node: HTMLElement, lens: string) {
  return {
    x: Number(node.dataset[`x${lens[0].toUpperCase()}${lens.slice(1)}`]),
    y: Number(node.dataset[`y${lens[0].toUpperCase()}${lens.slice(1)}`]),
  };
}

function applyLens(lens: string) {
  for (const button of lensButtons) {
    const isActive = button.dataset.lensButton === lens;
    button.classList.toggle('active', isActive);
    button.setAttribute('aria-pressed', String(isActive));
  }
  for (const node of nodeElements) {
    const point = pointFor(node, lens);
    node.style.left = `${point.x}px`;
    node.style.top = `${point.y}px`;
  }
  for (const line of lineElements) {
    const source = nodesByKey.get(line.dataset.source || '');
    const target = nodesByKey.get(line.dataset.target || '');
    if (!source || !target) continue;
    const s = pointFor(source, lens);
    const t = pointFor(target, lens);
    line.setAttribute('x1', String(s.x));
    line.setAttribute('y1', String(s.y));
    line.setAttribute('x2', String(t.x));
    line.setAttribute('y2', String(t.y));
  }
  for (const label of lineLabels) {
    const source = nodesByKey.get(label.dataset.source || '');
    const target = nodesByKey.get(label.dataset.target || '');
    if (!source || !target) continue;
    const s = pointFor(source, lens);
    const t = pointFor(target, lens);
    label.setAttribute('x', String(Math.round((s.x + t.x) / 2)));
    label.setAttribute('y', String(Math.round((s.y + t.y) / 2)));
  }
}

for (const button of lensButtons) {
  button.addEventListener('click', () => applyLens(button.dataset.lensButton || 'conceito'));
}
</script>

<style is:global>
body.page-map{background:#ece5d8;color:#111}
body.page-map a{text-decoration:none}
</style>

<style>
.map-page{min-height:100vh;background:#ece5d8;color:#111;padding:1.25rem 1rem 2rem}
.back,.legacy-link,.map-kicker,.map-meta,.node-meta,.map-lines text{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase}
.surface-links{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem}
.back,.legacy-link{display:inline-block;color:rgba(17,17,17,.58)}
.legacy-link{color:rgba(17,17,17,.42)}
.back:hover,.legacy-link:hover{color:#111}
.map-kicker{color:rgba(17,17,17,.46);margin-bottom:.6rem}
.map-head h1{font:800 clamp(2.4rem,6vw,4.5rem)/.95 var(--sans);letter-spacing:-.05em;margin-bottom:.75rem}
.map-head p{max-width:52ch;font:1rem/1.65 var(--sans);color:rgba(17,17,17,.75);margin-bottom:.75rem}
.map-meta{color:rgba(17,17,17,.48);margin-bottom:1.5rem}
.map-shell{overflow:auto;border-top:1px solid rgba(17,17,17,.18);padding-top:1rem}
.lens-controls{display:flex;gap:.5rem;flex-wrap:wrap;margin:0 0 .85rem}
.lens-controls button{font:.72rem/1 var(--mono);letter-spacing:.12em;text-transform:uppercase;background:transparent;color:rgba(17,17,17,.48);border:1px solid rgba(17,17,17,.16);padding:.48rem .62rem;cursor:pointer}
.lens-controls button:hover{color:#111;border-color:rgba(17,17,17,.34)}
.lens-controls button.active{background:#111;color:#ece5d8;border-color:#111}
.map-legend{display:flex;gap:1rem 1.25rem;flex-wrap:wrap;margin:0 0 .9rem;font:.72rem/1.4 var(--mono);letter-spacing:.08em;text-transform:uppercase;color:rgba(17,17,17,.5)}
.map-legend strong{color:#111;font-weight:500}
.map-field{position:relative;min-width:1180px;height:820px;background:rgba(255,255,255,.14);border:1px solid rgba(17,17,17,.16)}
.map-lines{position:absolute;inset:0;width:100%;height:100%}
.map-lines line{stroke:rgba(17,17,17,.18);stroke-width:1.2;transition:all .32s ease}
.map-lines text{fill:rgba(17,17,17,.45);font-size:10px;text-anchor:middle;dominant-baseline:middle;transition:all .32s ease}
.map-node{position:absolute;transform:translate(-50%,-50%);display:flex;flex-direction:column;gap:.2rem;max-width:220px;transition:left .32s ease,top .32s ease,background .15s ease,border-color .15s ease}
.map-node.obra,.map-node.escrito,.map-node.publicacao{padding:.55rem .65rem .6rem;background:#f6f1e8;border:1px solid rgba(17,17,17,.16);border-left:4px solid var(--node-color,#111)}
.map-node.referencia{padding:.2rem 0;max-width:none}
.node-label{font:.95rem/1.25 var(--sans);color:#111;letter-spacing:-.02em}
.node-meta{color:rgba(17,17,17,.48)}
.map-node.referencia .node-label{font:.88rem/1.2 var(--sans);font-style:italic;color:rgba(17,17,17,.72)}
.map-node.referencia .node-meta{display:none}
.map-node:hover{z-index:2}
.map-node.obra:hover,.map-node.escrito:hover,.map-node.publicacao:hover{background:#fffdf8}
@media (min-width: 900px){
  .map-page{padding:1.5rem 2rem 2.5rem}
}
</style>
